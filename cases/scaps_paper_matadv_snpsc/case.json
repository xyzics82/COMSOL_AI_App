{
  "id": "scaps_paper_matadv_snpsc",
  "name": "SCAPS-1D 판별 케이스 — Sn계 PSC (Mater. Adv., 버전 3.3.12 명시)",
  "desc": "오픈액세스 Materials Advances 논문(bilayer tin-based PSC, SCAPS 3.3.12 사용 명시) 중 단층 CsSnI3 셀(FTO/PCBM/CsSnI3/CFTS/Au) 재현. 목적: 우리 3.3.12 설치본의 0.78V 벽이 전 소자 공통인지, Energies·Crystals 조합 특이인지 판별. 최초 1회: 실행 후 ④ recipe_paper.md 표대로 GUI 4층 제작 → paper_matadv_sn.def 저장. 기준: 흡수층 1.0μm에서 PCE 15.75% (Voc/Jsc/FF 개별값은 논문 그림만 제공). 스윕: 두께 0.1-1.5μm / 벌크 Nt / 계면 Nt(논문 임계 1e14 cm⁻²). 가정 명시: 계면 Nt 1e10(표 렌더 손상 추정), 벌크 σ 1e-15·midgap, flat band 접점.",
  "engine": "scaps",
  "schema": [
    {"key": "def_name", "label": "SCAPS def 파일명 (GUI로 1회 제작)", "type": "text", "default": "paper_matadv_sn.def"},
    {"key": "v_max", "label": "I-V 최대 전압 [V] (Voc~0.9급)", "type": "number", "default": 1.1},
    {"key": "v_step", "label": "I-V 스텝 [V]", "type": "number", "default": 0.02},
    {"key": "rs_ohmcm2", "label": "직렬저항 Rs [Ω·cm²] (미기재 → 0=생략)", "type": "number", "default": 0},
    {"key": "rsh_ohmcm2", "label": "션트저항 Rsh [Ω·cm²] (미기재 → 무한=생략)", "type": "number", "default": 1e30},
    {"key": "do_qe", "label": "QE(300-900nm) 계산", "type": "select", "options": ["no", "yes"], "default": "no"},
    {"key": "use_measured_alpha", "label": "Phillips α 주입 (Sn계엔 부적합 — no 유지)", "type": "select", "options": ["no", "yes"], "default": "no"},
    {"key": "bulk_sigma_cm2", "label": "흡수층 결함 σ [cm²] (미기재 가정 1e-15)", "type": "number", "default": 1e-15},
    {"key": "stabilize", "label": "수렴 안정화 (single→uniform 수치등가)", "type": "select", "options": ["none", "bulk_uniform", "bulk+interface_uniform"], "default": "none"},
    {"key": "sweep_what", "label": "스윕 (none=기준만)", "type": "select",
     "options": ["none", "absorber_thickness_um (0.1-1.5)", "absorber_defect_Nt [1/cm3]", "interface_defect_Nt [1/cm2] (양쪽)"],
     "default": "none"},
    {"key": "sweep_values", "label": "스윕 값 (쉼표 — 두께: 0.1,0.4,0.7,1.0,1.5 / 계면Nt: 1e10,1e12,1e14,1e16)", "type": "text", "default": "0.1,0.4,0.7,1.0,1.5"},
    {"key": "extra_set", "label": "추가 set 명령 (고급·진단)", "type": "text", "default": ""},
    {"key": "mode", "label": "실행 방식", "type": "select", "options": ["local", "export"], "default": "local"}
  ],
  "data_requirements": []
}
