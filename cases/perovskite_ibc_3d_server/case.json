{
  "id": "perovskite_ibc_3d_server",
  "name": "🌙 [서버 local·밤샘] IBC 3D 정밀 그리드 — 풀 솔브 + solved 저장",
  "desc": "HPC 반출 케이스의 '그 자리에서 끝까지 솔브' 버전. 앱을 통째로 복사한 서버(방법 B, docs/SERVER_GUIDE.md)에서 local로 실행해 두고 퇴근하는 용도: 조합별로 솔브 → *_solved.mph 저장 → J-V 지표(Jsc/Voc/FF/PCE) 추출 → 종료 시 히트맵 4종 + J-V 곡선 + CSV까지 자동 생성. 실패 조합은 건너뛰고 계속 진행, 중간 취소해도 완료분 보존. ⚠️ 장시간 작업: 기본 15조합×hmax 80nm×풀 J-V(41점)는 조합당 수십 분 — 밤샘 규모. 이 PC에서도 실행은 되지만 낮 작업을 막으므로 서버 권장. 잠금(hpc_only)은 없음.",
  "builder": "ibc3d",
  "grid": {
    "x": {"param": "W_um", "field": "w_list_um", "label": "전극 폭 W [um]"},
    "y": {"param": "gap_um", "field": "gap_list_um", "label": "간격 gap [um]"}
  },
  "schema": [
    {"key": "w_list_um", "label": "전극 폭 W 목록 [um]", "type": "text", "default": "1,2,3,4,5"},
    {"key": "gap_list_um", "label": "n/p 간격 gap 목록 [um]", "type": "text", "default": "1,2,3"},
    {"key": "finger_len_um", "label": "단위 셀 z 길이 [um]", "type": "number", "default": 6},
    {"key": "tip_len_um", "label": "핑거(CTL) 길이 [um] (< z 길이 = 끝단 효과 포함)", "type": "number", "default": 5},
    {"key": "t_abs_nm", "label": "흡수층 두께 [nm]", "type": "number", "default": 800},
    {"key": "taun_ns", "label": "흡수층 SRH τ [ns]", "type": "number", "default": 38.7},
    {"key": "s_ifc_cms", "label": "계면 재결합 속도 S [cm/s] (IDL 2nm 등가)", "type": "number", "default": 1000},
    {"key": "mesh_hmax_nm", "label": "메시 최대 크기 [nm] (80=정량 검증 대역, 60=더 촘촘·시간 ~2배)", "type": "number", "default": 80},
    {"key": "nlam", "label": "광학 λ 샘플 수 (15점은 Jsc,opt ~3% 과대 — 31 권장, 광학은 1회만 계산)", "type": "number", "default": 31},
    {"key": "jv_mode", "label": "J-V 범위", "type": "select", "options": ["full_jv", "jsc_only"], "default": "full_jv"},
    {"key": "gen_mode", "label": "광생성 모델", "type": "select", "options": ["wave_optics", "beer_lambert"], "default": "wave_optics"},
    {"key": "mode", "label": "실행 방식 (local=이 컴퓨터에서 끝까지 솔브)", "type": "select", "options": ["local", "export"], "default": "local"}
  ],
  "data_requirements": ["am15", "mapbi3_nk"]
}
