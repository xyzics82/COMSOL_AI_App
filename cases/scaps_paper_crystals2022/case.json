{
  "id": "scaps_paper_crystals2022",
  "name": "SCAPS-1D 논문 재현 2 — FTO/TiO2/MAPbI3/Spiro (Crystals 2022, 실험검증)",
  "desc": "오픈액세스 Crystals 2022, 12(1), 68 (doi:10.3390/cryst12010068) 재현. 실험 소자(암비언트 제작, Eg 1.45)와 시뮬이 동시 일치하는 검증 모델 — 순정렬 밴드라 energies2023의 역정렬 발산 문제가 없음. 최초 1회: 실행 후 ④의 recipe_paper.md 표대로 GUI에서 4층+일함수 접점 소자를 만들어 paper_crystals2022.def 저장. 이후 전자동: 기준 J-V(+QE) → 논문 지표(Jsc 25.81/Voc 0.8001/FF 42.37/η 8.75, Nt=9e16)와 비교표 → 논문 그림 스윕(Fig.3 결함밀도: Voc 0.80→0.90, η 8.75→15.87 / Fig.4 두께 / Fig.6-7 χ). 논문 미기재: 계면 Nt(1e9 가정), Rs/Rsh(0/무한).",
  "engine": "scaps",
  "schema": [
    {"key": "def_name", "label": "SCAPS def 파일명 (GUI로 1회 제작)", "type": "text", "default": "paper_crystals2022.def"},
    {"key": "v_max", "label": "I-V 최대 전압 [V] (Voc~0.80-0.90)", "type": "number", "default": 1.1},
    {"key": "v_step", "label": "I-V 스텝 [V]", "type": "number", "default": 0.02},
    {"key": "rs_ohmcm2", "label": "직렬저항 Rs [Ω·cm²] (논문 미기재 → 0)", "type": "number", "default": 0},
    {"key": "rsh_ohmcm2", "label": "션트저항 Rsh [Ω·cm²] (논문 미기재 → 무한)", "type": "number", "default": 1e30},
    {"key": "do_qe", "label": "QE(300-900nm) 계산 (논문 Fig.2b)", "type": "select", "options": ["yes", "no"], "default": "yes"},
    {"key": "use_measured_alpha", "label": "Phillips α 주입 — 이 소자(Eg 1.45)엔 부적합, no 유지", "type": "select", "options": ["no", "yes"], "default": "no"},
    {"key": "bulk_sigma_cm2", "label": "흡수층 결함 σ [cm²] (논문 명시 1e-15)", "type": "number", "default": 1e-15},
    {"key": "stabilize", "label": "수렴 안정화 (필요시 — single→uniform 수치등가)", "type": "select", "options": ["none", "bulk_uniform", "bulk+interface_uniform"], "default": "none"},
    {"key": "sweep_what", "label": "논문 그림 스윕 (none=기준만)", "type": "select",
     "options": ["none", "absorber_defect_Nt [1/cm3] (Fig.3)", "absorber_thickness_um (Fig.4)", "ETL_chi [eV] (Fig.6, 3.4-4.3)", "HTL_chi [eV] (Fig.7, 2.0-2.7)"],
     "default": "none"},
    {"key": "sweep_values", "label": "스윕 값 (쉼표 — Nt: 1e11,1e13,1e15,9e16 / 두께um: 0.2,0.3,0.4,0.51,0.6)", "type": "text", "default": "1e11,1e13,1e15,9e16"},
    {"key": "extra_set", "label": "추가 set 명령 (고급·진단, 세미콜론 구분)", "type": "text", "default": ""},
    {"key": "mode", "label": "실행 방식", "type": "select", "options": ["local", "export"], "default": "local"}
  ],
  "data_requirements": []
}
