{
  "id": "scaps_pin_reference",
  "name": "SCAPS-1D 기준 소자 — n-i-p J-V (COMSOL 계면 S 대조)",
  "desc": "SnO2/MAPbI3/NiOx n-i-p를 SCAPS로: 같은 물성(materials.json)·같은 계면 S로 COMSOL IDL 구현을 독립 대조. 실행하면 GUI 입력용 레시피(recipe.md, 결함 환산식 포함)와 배치 스크립트를 생성. SCAPS에서 계산한 .iv/.qe를 ③ '결과 가져오기'에 업로드하면 지표·플롯 자동(파서는 즉시 사용 가능). ⚠️ SCAPS는 겐트대 이메일 신청으로 설치(무료) — CLI 자동 구동·스크립트 문법은 첫 실행 때 검증.",
  "engine": "scaps",
  "schema": [
    {"key": "t_abs_nm", "label": "흡수층 두께 [nm]", "type": "number", "default": 800},
    {"key": "t_etl_nm", "label": "ETL(SnO2) 두께 [nm]", "type": "number", "default": 20},
    {"key": "t_htl_nm", "label": "HTL(NiOx) 두께 [nm]", "type": "number", "default": 10},
    {"key": "taun_ns", "label": "흡수층 SRH τ [ns]", "type": "number", "default": 38.7},
    {"key": "s_ifc_cms", "label": "계면 재결합 속도 S [cm/s]", "type": "number", "default": 1000},
    {"key": "v_max", "label": "I-V 최대 전압 [V]", "type": "number", "default": 1.3},
    {"key": "v_step", "label": "I-V 스텝 [V]", "type": "number", "default": 0.02},
    {"key": "mode", "label": "실행 방식 (export=레시피·스크립트 생성 / local=scaps.exe 시도)", "type": "select", "options": ["export", "local"], "default": "export"}
  ],
  "data_requirements": ["am15"]
}
